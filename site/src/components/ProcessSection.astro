---
import SectionHead from "./SectionHead.astro";
import type { Strings } from "../i18n/en";

interface Props {
  t: Strings;
}

const { t } = Astro.props;
---

<section id="how" class="process" aria-labelledby="process-h2">
  <div class="wrap">
    <SectionHead
      tag={t.process.tag}
      h2={t.process.h2}
      sub={t.process.sub}
      headingId="process-h2"
    />
    <div class="process__steps">
      {t.process.steps.map((step) => (
        <article class="step">
          <p class="step__num">{step.num}</p>
          <p class="step__when">{step.when}</p>
          <h3 class="step__h">{step.h}</h3>
          <p class="step__out-label">{t.process.outLabel}</p>
          <ul class="step__items">
            {step.items.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .process {
    padding-block: var(--sp-4xl);
    border-block-start: 0.5px solid var(--rule);
    background: var(--bg);
  }

  .process__steps {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border: 0.5px solid var(--rule);
    background: var(--paper);
  }

  .step {
    padding: 28px 24px;
    border-inline-end: 0.5px solid var(--rule);
    display: flex;
    flex-direction: column;
  }

  .step:last-child {
    border-inline-end: 0;
  }

  .step__num {
    margin: 0 0 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--signal);
  }

  .step__when {
    margin: 0 0 18px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .step__h {
    margin: 0 0 14px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 17px;
    line-height: 1.3;
    letter-spacing: -0.005em;
    color: var(--ink);
  }

  .step__out-label {
    margin: 0 0 10px;
    padding-block-start: 14px;
    border-block-start: 0.5px solid var(--rule);
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
  }

  .step__items {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .step__items li {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.5;
    color: var(--ink);
    padding-block: 6px;
    display: flex;
    gap: 8px;
  }

  .step__items li::before {
    content: "→";
    color: var(--structure);
    font-family: var(--font-mono);
    flex-shrink: 0;
  }

  html[dir="rtl"] .step__items li::before {
    content: "←";
  }

  html[dir="rtl"] .step__num,
  html[dir="rtl"] .step__when,
  html[dir="rtl"] .step__out-label {
    direction: ltr;
    text-align: start;
  }

  [lang="ar"] .step__h,
  html[dir="rtl"] .step__h {
    font-size: 17px;
    line-height: 1.5;
    letter-spacing: 0;
  }

  [lang="ar"] .step__items li,
  html[dir="rtl"] .step__items li {
    font-size: 14px;
    line-height: 1.7;
  }

  @media (max-width: 1023px) {
    .process__steps {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .step:nth-child(2n) {
      border-inline-end: 0;
    }
    .step:nth-child(-n + 2) {
      border-block-end: 0.5px solid var(--rule);
    }
  }

  @media (max-width: 640px) {
    .process {
      padding-block: var(--sp-2xl);
    }
    .process__steps {
      grid-template-columns: 1fr;
    }
    .step {
      border-inline-end: 0;
      border-block-end: 0.5px solid var(--rule);
    }
    .step:last-child {
      border-block-end: 0;
    }
  }
</style>
