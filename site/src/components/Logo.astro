<style>
  .brand {
    display: inline-flex;
    align-items: center;
    color: var(--ink);
    line-height: 0;
  }

  .brand__wordmark,
  .brand__icon {
    display: block;
    width: auto;
  }

  .brand__icon {
    display: none;
    aspect-ratio: 1 / 1;
  }

  @media (max-width: 340px) {
    .brand__wordmark {
      display: none;
    }
    .brand__icon {
      display: block;
      height: 40px;
    }
  }
</style>
