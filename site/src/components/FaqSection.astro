---
import SectionHead from "./SectionHead.astro";
import type { Strings } from "../i18n/en";

interface Props {
  t: Strings;
}

const { t } = Astro.props;

function slug(s: string, idx: number) {
  return `faq-${idx + 1}`;
}
---

<section id="faq" class="faq" aria-labelledby="faq-h2">
  <div class="wrap">
    <SectionHead
      tag={t.faq.tag}
      h2={t.faq.h2}
      sub={t.faq.sub}
      headingId="faq-h2"
    />
    <ol class="faq__list">
      {t.faq.items.map((item, idx) => (
        <li class="faq__item">
          <details id={slug(item.q, idx)} class="faq__details">
            <summary class="faq__q">
              <span class="faq__num">{String(idx + 1).padStart(2, "0")}</span>
              <span class="faq__q-text">{item.q}</span>
              <span class="faq__toggle" aria-hidden="true">+</span>
            </summary>
            <div class="faq__a">
              <p>{item.a}</p>
            </div>
          </details>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .faq {
    padding-block: var(--sp-4xl);
    border-block-start: 0.5px solid var(--rule);
  }

  .faq__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-block-start: 0.5px solid var(--rule);
  }

  .faq__item {
    border-block-end: 0.5px solid var(--rule);
  }

  .faq__details {
    /* native */
  }

  .faq__q {
    list-style: none;
    cursor: pointer;
    display: grid;
    grid-template-columns: 60px minmax(0, 1fr) 24px;
    gap: var(--sp-base);
    align-items: center;
    padding-block: var(--sp-lg);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    line-height: 1.3;
    color: var(--ink);
    transition: color var(--dur-short) var(--ease-out);
  }

  .faq__q::-webkit-details-marker {
    display: none;
  }

  .faq__q:hover {
    color: var(--muted);
  }

  .faq__num {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
  }

  .faq__toggle {
    justify-self: end;
    width: 22px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0.5px solid var(--rule);
    font-family: var(--font-mono);
    font-size: 16px;
    line-height: 1;
    color: var(--structure);
    transition:
      transform var(--dur-short) var(--ease-out),
      color var(--dur-short) var(--ease-out),
      border-color var(--dur-short) var(--ease-out);
  }

  .faq__details[open] .faq__toggle {
    color: var(--ink);
    border-color: var(--ink);
    transform: rotate(45deg);
  }

  .faq__a {
    padding-block-end: var(--sp-lg);
    padding-inline-start: calc(60px + var(--sp-base));
    padding-inline-end: calc(24px + var(--sp-base));
    max-width: var(--max-prose);
  }

  .faq__a p {
    margin: 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 16px;
    line-height: 1.6;
    color: var(--muted);
  }

  [lang="ar"] .faq__q,
  html[dir="rtl"] .faq__q {
    font-size: 18px;
    line-height: 1.5;
    letter-spacing: 0;
  }

  [lang="ar"] .faq__a p,
  html[dir="rtl"] .faq__a p {
    font-size: 17px;
    line-height: 1.8;
  }

  @media (max-width: 767px) {
    .faq {
      padding-block: var(--sp-2xl);
    }
    .faq__q {
      grid-template-columns: 40px minmax(0, 1fr) 20px;
      font-size: 16px;
      padding-block: var(--sp-md);
      gap: var(--sp-sm);
    }
    .faq__a {
      padding-inline-start: calc(40px + var(--sp-sm));
      padding-inline-end: var(--sp-sm);
      padding-block-end: var(--sp-md);
    }
  }
</style>
