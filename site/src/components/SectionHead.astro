---
interface Props {
  tag: string;
  h2: string;
  sub?: string;
  headingId?: string;
}

const { tag, h2, sub, headingId } = Astro.props;
---

<header class="section-head">
  <div class="section-head__primary">
    <p class="section-head__tag">{tag}</p>
    <h2 id={headingId} class="section-head__h2">{h2}</h2>
  </div>
  {sub && <p class="section-head__sub">{sub}</p>}
</header>

<style>
  .section-head {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--sp-2xl);
    margin-block-end: var(--sp-2xl);
    align-items: end;
  }

  .section-head__primary {
    display: flex;
    flex-direction: column;
    gap: var(--sp-sm);
  }

  .section-head__tag {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
  }

  [lang="ar"] .section-head__tag,
  html[dir="rtl"] .section-head__tag {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 15px;
    line-height: 1.5;
    letter-spacing: 0;
    text-transform: none;
    direction: rtl;
    text-align: start;
  }

  .section-head__h2 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(28px, 3.4vw, 38px);
    line-height: 1.15;
    letter-spacing: -0.012em;
    color: var(--ink);
    text-wrap: balance;
  }

  .section-head__sub {
    margin: 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 16px;
    line-height: 1.55;
    color: var(--muted);
    max-width: 48ch;
  }

  [lang="ar"] .section-head__h2,
  html[dir="rtl"] .section-head__h2 {
    font-size: clamp(26px, 3.2vw, 36px);
    letter-spacing: 0;
    line-height: 1.3;
  }

  [lang="ar"] .section-head__sub,
  html[dir="rtl"] .section-head__sub {
    font-size: 17px;
    line-height: 1.7;
  }

  @media (max-width: 1023px) {
    .section-head {
      grid-template-columns: 1fr;
      gap: var(--sp-md);
      align-items: start;
    }
  }
</style>
